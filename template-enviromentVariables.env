# --- Keycloak y OAuth2 para OpenMRS (Producción) ---
# Variables para integración segura de OpenMRS con Keycloak vía OAuth2
# Personaliza todos los valores antes de usar en producción

# Keycloak
# URL pública de Keycloak (usar HTTPS en producción)
KEYCLOAK_URL=https://keycloak.tudominio.com
# Nombre del realm configurado en Keycloak
KEYCLOAK_REALM=openmrs
# ID del cliente OAuth2 creado en Keycloak
KEYCLOAK_CLIENT_ID=openmrs-oauth-client
# Secreto del cliente (confidencial, generado en Keycloak)
KEYCLOAK_CLIENT_SECRET=pon_aqui_tu_secret_fuerte
# Usuario administrador de Keycloak (solo para gestión inicial)
KEYCLOAK_ADMIN_USER=pon_admin
KEYCLOAK_ADMIN_PASSWORD=pon_password_fuerte

# OpenMRS OAuth2 Module
# Deben coincidir con los valores configurados en Keycloak
OMRS_OAUTH_CLIENT_ID=openmrs-oauth-client
OMRS_OAUTH_CLIENT_SECRET=pon_aqui_tu_secret_fuerte
OMRS_OAUTH_ISSUER=https://keycloak.tudominio.com/realms/openmrs
OMRS_OAUTH_REDIRECT_URI=https://openmrs.tudominio.com/openmrs/module/oauth2login/redirect.action

# Recomendaciones de seguridad:
# - Cambia todos los valores por los definitivos de tu entorno.
# - Usa HTTPS en producción.
# - El CLIENT_SECRET debe ser el mismo que configures en el cliente de Keycloak.
# - El REDIRECT_URI debe coincidir exactamente con el configurado en Keycloak.
# - El usuario y password de admin son para la gestión inicial, cámbialos luego por seguridad.

